# ============================================
# .dockerignore — keep the image lean
# ============================================

# Git
.git
.gitignore

# Docker files (don't copy into the image)
Dockerfile
docker-compose.yml
Caddyfile
.dockerignore
.env
.env.example

# Training scripts & datasets (not needed at runtime)
training/
analysis/
datasets/
*.ipynb

# Output artifacts (generated at runtime)
output/

# Python cache
__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
build/
.eggs/

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Logs
*.log
