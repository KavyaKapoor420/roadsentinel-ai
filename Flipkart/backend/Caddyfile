# ============================================
# Caddy Reverse Proxy Configuration
# Auto TLS via Let's Encrypt for FreeDNS domain
# ============================================
#
# Prerequisites:
#   1. fgr2-backend.mooo.com A record → your GCP VM's external IP
#   2. Ports 80 and 443 open in GCP firewall
#   3. That's it — Caddy handles cert issuance + renewal automatically
#

fgr2-backend.mooo.com {
	# ── Reverse proxy to FastAPI ──
	reverse_proxy app:8000 {
		# Health check — Caddy marks upstream unhealthy if it fails
		health_uri /api/health
		health_interval 30s
		health_timeout 10s

		# Pass real client IP to FastAPI
		header_up X-Real-IP {remote_host}
		header_up X-Forwarded-For {remote_host}
		header_up X-Forwarded-Proto {scheme}
	}

	# ── Security headers ──
	header {
		# HSTS — tell browsers to always use HTTPS
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		# Prevent MIME-type sniffing
		X-Content-Type-Options "nosniff"
		# Clickjacking protection
		X-Frame-Options "DENY"
		# XSS protection
		X-XSS-Protection "1; mode=block"
		# Hide server identity
		-Server
	}

	# ── Request size limit (matches FastAPI's MAX_UPLOAD_SIZE_MB=500) ──
	request_body {
		max_size 500MB
	}

	# ── Logging ──
	log {
		output stdout
		format json
		level INFO
	}

	# ── Compression ──
	encode gzip zstd
}
